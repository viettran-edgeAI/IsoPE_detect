{
  "feature_selection": {
    "top_k_list": [40, 100]
  },
  "model": {
    "n_estimators": [200],
    "max_samples": [0.5, 0.7, 1.0],
    "contamination": [0.005],
    "max_features": [0.6, 0.8, 1.0],
    "bootstrap": [false, true],
    "random_state": 42,
    "n_jobs": -1
  },
  "thresholding": {
    "fpr_threshold": 0.05,
    "val_fpr_delta": 0.01,
    "strategy": "tpr",
    "f_beta": 1.0,
    "expose_test_during_search": false
  },
  "independence_audit": {
    "max_cross_similarity": 0.995,
    "mmd_permutations": 300,
    "require_min_malware_val_samples": 80,
    "max_malware_val_percent_of_benign_train": 5
  }
}
