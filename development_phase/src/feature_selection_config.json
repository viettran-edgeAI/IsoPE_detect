{
  "data": {
    "train_benign_path": "../data/raw/benign_train_raw.parquet",
    "val_benign_path": "../data/raw/benign_val_raw.parquet",
    "test_benign_path": "../data/raw/benign_test_raw.parquet",
    "test_malware_path": "../data/raw/malware_test_raw.parquet",
    "val_malware_path": "../data/raw/malware_val_raw.parquet"
  },
  "filtering": {
    "variance_threshold": 0.008,
    "norm_var_threshold": 1e-7,
    "corr_threshold": 0.95
  },
  "separation_control": {
    "enabled": true,
    "min_val_ratio_to_benign_test": 0.05,
    "max_val_ratio_to_benign_test": 0.08,
    "near_dup_cosine_threshold": 0.995,
    "random_seed": 42
  },
  "outputs": {
    "cleaned_data_dir": "../data/cleaned",
    "schema_dir": "../schemas",
    "report_dir": "../reports"
  }
}
