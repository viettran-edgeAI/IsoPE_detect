{
  "version": 8,
  "configurePresets": [
    {
      "name": "linux-gcc-debug",
      "displayName": "Linux GCC (Debug)",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build_cmake_tools",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "msys2-mingw64-release",
      "displayName": "MSYS2 MinGW64 + Ninja (GNU Release)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/msys2-mingw64-release",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "environment": {
        "PATH": "C:/msys64/usr/bin;C:/msys64/mingw64/bin;$penv{PATH}"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_C_COMPILER": "C:/msys64/mingw64/bin/gcc.exe",
        "CMAKE_CXX_COMPILER": "C:/msys64/mingw64/bin/g++.exe"
      }
    },
    {
      "name": "msvc-ninja-release",
      "displayName": "MSVC + Ninja (Release)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/msvc-ninja-release",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "msvc-ninja-debug",
      "displayName": "MSVC + Ninja (Debug)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/msvc-ninja-debug",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "linux-gcc-debug-build",
      "displayName": "Build Linux GCC (Debug)",
      "configurePreset": "linux-gcc-debug",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "msys2-mingw64-release-build",
      "displayName": "Build MSYS2 MinGW64 + Ninja (Release)",
      "configurePreset": "msys2-mingw64-release",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "msvc-ninja-release-build",
      "displayName": "Build MSVC Ninja (Release)",
      "configurePreset": "msvc-ninja-release",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "msvc-ninja-debug-build",
      "displayName": "Build MSVC Ninja (Debug)",
      "configurePreset": "msvc-ninja-debug",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    }
  ],
  "testPresets": [
    {
      "name": "linux-gcc-debug-test",
      "displayName": "CTest Linux GCC (Debug)",
      "configurePreset": "linux-gcc-debug",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "msys2-mingw64-release-test",
      "displayName": "CTest MSYS2 MinGW64 + Ninja (Release)",
      "configurePreset": "msys2-mingw64-release",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}